<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="edu.westga.comp2320.babynames.controller.BabyNameController">

    <padding>
        <Insets top="10" right="10" bottom="10" left="10"/>
    </padding>

    <!-- 🔥 REQUIRED MENU BAR (PART 1.4) -->
    <MenuBar>
        <Menu text="File">
            <MenuItem text="Open" onAction="#handleOpen" accelerator="Ctrl+O"/>
            <MenuItem text="Save" onAction="#handleSave" accelerator="Ctrl+S"/>
        </Menu>
        <Menu text="Help">
            <MenuItem text="About" onAction="#handleAbout" accelerator="Ctrl+B"/>
        </Menu>
    </MenuBar>

    <Label text="Frequencies of Baby Names by Year"/>

    <TextField fx:id="nameField" promptText="Name"/>

    <HBox spacing="10">
        <RadioButton fx:id="maleRadio" text="M"/>
        <RadioButton fx:id="femaleRadio" text="F"/>
    </HBox>

    <TextField fx:id="yearField" promptText="Year"/>
    <Label fx:id="yearErrorLabel" textFill="red"/>

    <TextField fx:id="frequencyField" promptText="Frequency"/>

    <HBox spacing="10">
        <Button text="Search" onAction="#handleSearch"/>
        <Button text="Add" onAction="#handleAdd"/>
        <Button text="Clear" onAction="#handleClear"/>
        <Button text="Top 3" onAction="#handleTopNames"/>
    </HBox>

    <HBox spacing="10">
        <Button fx:id="deleteButton" text="Delete" onAction="#handleDelete"/>
        <Button text="Delete All" onAction="#handleDeleteAll"/>
    </HBox>

    <ListView fx:id="listView" prefHeight="200"/>

</VBox>